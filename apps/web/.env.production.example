# CHINA ORDER TZ — Production environment (Next.js)
# Copy to .env.production before deploy: cp .env.production.example .env.production
# Set real values in your hosting provider (Vercel, Railway, VPS, etc.).

# ── Public URLs (required) ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# ── Payment — M-Pesa Daraja (server-only) ───────────────────────────────────
PAYMENT_MODE=live
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback
MPESA_BASE_URL=https://api.safaricom.co.ke

# ── Admin auth (required in production — no defaults) ─────────────────────────
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_PASSWORD=

# ── Realtime transport ────────────────────────────────────────────────────────
# Vercel/serverless: use polling (default). Custom VPS with server.ts: set WS URLs.
NEXT_PUBLIC_ADMIN_REALTIME_MODE=auto
# NEXT_PUBLIC_WS_BASE_URL=wss://your-domain.com
# NEXT_PUBLIC_ADMIN_WS_URL=wss://your-domain.com/ws/admin/orders
# NEXT_PUBLIC_ORDER_TRACKING_WS_URL=wss://your-domain.com/ws/orders/tracking
# NEXT_PUBLIC_NOTIFICATIONS_WS_URL=wss://your-domain.com/ws/notifications
NEXT_PUBLIC_ADMIN_POLL_INTERVAL_MS=5000
NEXT_PUBLIC_ADMIN_POLL_INTERVAL_HIDDEN_MS=30000

# ── Persistent store (recommended for production) ───────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ADMIN_ORDERS_REDIS_CHANNEL=admin:orders:events

# ── Optional ──────────────────────────────────────────────────────────────────
# ENABLE_DEBUG_LOGS=false
