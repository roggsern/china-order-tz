# Frontend (Next.js) — local development
# Copy to .env.local: cp .env.example .env.local

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side fetches inside Docker Compose (optional locally; set in docker-compose.yml)
# API_INTERNAL_URL=http://nginx

# Admin dashboard login hint (shown on the form). Real auth is Laravel.
NEXT_PUBLIC_ADMIN_EMAIL=admin@chinaordertz.com

# Align with API SANCTUM_ADMIN_EXPIRATION_MINUTES (default 480 minutes = 8 hours).
ADMIN_TOKEN_MAX_AGE_SECONDS=28800

# ADMIN_API_EMAIL / ADMIN_API_PASSWORD are NOT used for BFF authentication (RC1-G4A).
# They may exist only for offline maintenance tooling — never auto-login API requests.

# Payment — M-Pesa (server-only; never use NEXT_PUBLIC_* for secrets)
# PAYMENT_MODE=test enables simulate flow in development only.
PAYMENT_MODE=test
MPESA_CALLBACK_URL=http://localhost:3000/api/payments/mpesa/callback
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# Admin realtime transport
# NEXT_PUBLIC_ADMIN_REALTIME_MODE=auto | polling | websocket
# NEXT_PUBLIC_WS_BASE_URL=ws://localhost:3000
# NEXT_PUBLIC_ADMIN_WS_URL=ws://localhost:3000/ws/admin/orders
# NEXT_PUBLIC_ORDER_TRACKING_WS_URL=ws://localhost:3000/ws/orders/tracking
# NEXT_PUBLIC_NOTIFICATIONS_WS_URL=ws://localhost:3000/ws/notifications

# Optional Upstash Redis (recommended for production)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Debug logging (client + server payment logs)
# ENABLE_DEBUG_LOGS=true

# NMB Hosted Checkout (public gateway URL only — credentials stay on Laravel API)
# NEXT_PUBLIC_NMB_GATEWAY_URL=https://test-nmbbank.mtf.gateway.mastercard.com
# NEXT_PUBLIC_NMB_CHECKOUT_JS_URL=https://test-nmbbank.mtf.gateway.mastercard.com/static/checkout/checkout.min.js
# NEXT_PUBLIC_NMB_RETURN_URL=http://localhost:3000/payment/return

# Production template: see .env.production.example
