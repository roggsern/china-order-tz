{
  "name": "@china-order-tz/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "start:ws": "cross-env NODE_ENV=production tsx server.ts",
    "ws:server": "tsx ws/admin-orders-ws-server.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:storefront": "tsx --test src/lib/storefront/navigation-policy.test.ts src/lib/storefront/resolve-storefront-navigation.test.ts",
    "test:homepage": "tsx --test src/lib/content/homepage/*.test.ts",
    "test:unit": "tsx --test src/lib/storefront/navigation-policy.test.ts src/lib/storefront/resolve-storefront-navigation.test.ts src/lib/content/homepage/*.test.ts",

    "extract-branding": "node scripts/extract-branding.mjs",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.41.0",
    "libphonenumber-js": "^1.13.8",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "lightningcss": "1.32.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "ws": "^8.21.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.1",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
