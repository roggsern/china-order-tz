APP_NAME="CHINA ORDER TZ API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=china_order_tz
DB_USERNAME=china_order
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@chinaordertz.com"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

PAYMENT_DEFAULT_GATEWAY=mock
PAYMENT_NMB_ENABLED=false
NMB_BASE_URL=
NMB_CLIENT_ID=
NMB_CLIENT_SECRET=
NMB_MERCHANT_ID=
NMB_CALLBACK_URL=
NMB_TEST_MODE=true
PAYMENT_VODACOM_ENABLED=false
PAYMENT_AIRTEL_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
