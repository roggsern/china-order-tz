APP_NAME="CHINA ORDER TZ API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Local admin seed credentials (AdminSeeder) — must match web ADMIN_API_* / login form
ADMIN_SEED_EMAIL=admin@chinaordertz.com
ADMIN_SEED_PASSWORD=password

# Set true ONLY when you intentionally run migrate:fresh / db:wipe against Compose MySQL.
# Leave unset/false in normal development. PHPUnit uses sqlite :memory: and does not need this.
ALLOW_DESTRUCTIVE_DB=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=china_order_tz
DB_USERNAME=china_order
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@chinaordertz.com"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

PAYMENT_DEFAULT_GATEWAY=mock
PAYMENT_ORCHESTRATOR_DEFAULT_PROVIDER=nmb
PAYMENT_ORCHESTRATOR_MERCHANT_PREFIX=COTZ-PAY
PAYMENT_ORCHESTRATOR_MERCHANT_PADDING=6
# NMB production / sandbox credentials (never commit real secrets)
PAYMENT_NMB_ENABLED=false
NMB_ENVIRONMENT=sandbox
NMB_BASE_URL=
NMB_API_VERSION=85
NMB_MERCHANT_ID=
NMB_USERNAME=
NMB_PASSWORD=
NMB_RETURN_URL=
# Public callback for Payment Orchestrator: {API_URL}/api/v1/payments/nmb/callback
NMB_CALLBACK_URL=
NMB_MERCHANT_NAME="China Order TZ"
NMB_MERCHANT_URL=
NMB_AUTO_VERIFY_AFTER_CALLBACK=true
NMB_AUTO_COMPLETE_AFTER_VERIFICATION=true
NMB_PROCESS_CALLBACKS_ASYNC=true
NMB_HTTP_TIMEOUT=30
NMB_HTTP_CONNECT_TIMEOUT=10
NMB_HTTP_RETRY_TIMES=2
# PRODUCTION: set true and configure NMB_WEBHOOK_SECRET. false is local/sandbox only.
NMB_WEBHOOK_REQUIRE_SIGNATURE=false
NMB_WEBHOOK_SECRET=
NMB_WEBHOOK_REPLAY_TTL_SECONDS=86400
NMB_LOG_CHANNEL=stack
PAYMENT_VODACOM_ENABLED=false
PAYMENT_AIRTEL_ENABLED=false

# If NMB_PROCESS_CALLBACKS_ASYNC=true, run a queue worker:
#   php artisan queue:work database --sleep=1 --tries=3
# Or use the Compose `queue` service (see docker-compose.prod.yml).

# Notification Platform — providers are pluggable; only in-app delivers until configured
NOTIFICATION_EMAIL_DRIVER=smtp
NOTIFICATION_EMAIL_CONFIGURED=false
NOTIFICATION_WHATSAPP_DRIVER=meta_cloud
NOTIFICATION_WHATSAPP_CONFIGURED=false
NOTIFICATION_SMS_DRIVER=twilio
NOTIFICATION_SMS_CONFIGURED=false
NOTIFICATION_PUSH_DRIVER=firebase
NOTIFICATION_PUSH_CONFIGURED=false

# PRODUCTION checklist (do not ship defaults):
# APP_ENV=production
# APP_DEBUG=false
# LOG_LEVEL=warning|error
# SESSION_SECURE_COOKIE=true (HTTPS)
# PAYMENT_DEFAULT_GATEWAY=nmb (not mock)
# NMB_WEBHOOK_REQUIRE_SIGNATURE=true
# Rotate ADMIN_SEED_* / DB passwords before go-live

VITE_APP_NAME="${APP_NAME}"
