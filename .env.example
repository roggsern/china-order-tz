# CHINA ORDER TZ — Monorepo environment variables
# Copy to .env and adjust as needed: cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=china_order_tz
MYSQL_USER=china_order
MYSQL_PASSWORD=secret
MYSQL_PORT=3306

# Laravel API
APP_NAME="CHINA ORDER TZ API"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
API_PORT=8000

# Next.js frontend
WEB_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Payment — M-Pesa Daraja (server-only, never expose in NEXT_PUBLIC_*)
# Development: PAYMENT_MODE=test (default when unset in dev).
# Production: PAYMENT_MODE=live (required). See apps/web/.env.production.example
PAYMENT_MODE=test
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:3000/api/payments/mpesa/callback
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# Admin dashboard (optional — defaults to admin@china.com / admin123)
NEXT_PUBLIC_ADMIN_EMAIL=admin@china.com
NEXT_PUBLIC_ADMIN_PASSWORD=admin123

# Admin realtime — Vercel/serverless uses polling by default (no custom WebSocket server).
# NEXT_PUBLIC_ADMIN_REALTIME_MODE=auto | polling | websocket
# NEXT_PUBLIC_WS_BASE_URL=wss://your-domain.com
# NEXT_PUBLIC_ADMIN_WS_URL=wss://your-domain.com/ws/admin/orders
# NEXT_PUBLIC_ORDER_TRACKING_WS_URL=wss://your-domain.com/ws/orders/tracking
# NEXT_PUBLIC_NOTIFICATIONS_WS_URL=wss://your-domain.com/ws/notifications
# Polling interval (ms) for production admin dashboard:
# NEXT_PUBLIC_ADMIN_POLL_INTERVAL_MS=5000
# NEXT_PUBLIC_ADMIN_POLL_INTERVAL_HIDDEN_MS=30000

# Optional persistent order store + Redis pub/sub (Upstash — recommended for Vercel production)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# ADMIN_ORDERS_REDIS_CHANNEL=admin:orders:events
