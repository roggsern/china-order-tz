# CHINA ORDER TZ — Monorepo environment variables
# Copy to .env and adjust as needed: cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=china_order_tz
MYSQL_USER=china_order
MYSQL_PASSWORD=secret
MYSQL_PORT=3306

# Laravel API
APP_NAME="CHINA ORDER TZ API"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
# Required for production Compose (`docker-compose.prod.yml` env_file + APP_KEY interpolation).
# Generate: docker compose exec api php artisan key:generate --show
APP_KEY=
API_PORT=8000

# Backups (RC1-G4C2) — production Compose uses volume app_backups → /var/backups/china-order-tz
# BACKUP_ENABLED=true
# BACKUP_ROOT=/var/backups/china-order-tz
# BACKUP_RETENTION_DAILY=7
# BACKUP_RETENTION_WEEKLY=4
# BACKUP_RETENTION_MONTHLY=6
# BACKUP_DAILY_AT=02:15
# BACKUP_ENCRYPT=false
# Off-site foundation (optional): BACKUP_DRIVER=local|s3
# BACKUP_DRIVER=local
# BACKUP_S3_ACCESS_KEY_ID=
# BACKUP_S3_SECRET_ACCESS_KEY=
# BACKUP_S3_BUCKET=
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_PREFIX=china-order-tz

# Monitoring (RC1-G4C3)
# MONITORING_ENABLED=true
# ERROR_MONITORING_DRIVER=log
# ALERT_DRIVER=log
# ALERT_SLACK_WEBHOOK_URL=
# SENTRY_DSN=
# MONITORING_RELEASE=
# MONITORING_DISK_WARNING_PERCENT=90
# HEALTH_CRITICAL_ONLY=false
# MONITORING_FAILED_JOBS_WARNING=10
# MONITORING_PENDING_JOBS_WARNING=100
# QUEUE_WORKER_HEARTBEAT_TTL_SECONDS=300
# QUEUE_WORKER_STARTUP_GRACE_SECONDS=120

# Next.js frontend
WEB_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side Next.js → Laravel inside Docker Compose (not used when running web outside Docker)
API_INTERNAL_URL=http://nginx

# Payment — M-Pesa Daraja (server-only, never expose in NEXT_PUBLIC_*)
# Development: PAYMENT_MODE=test (default when unset in dev).
# Production: PAYMENT_MODE=live (required). See apps/web/.env.production.example
PAYMENT_MODE=test
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:3000/api/payments/mpesa/callback
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# NMB bank payments (Laravel API — see apps/api/.env.example for full list)
# Public callback: {API_URL}/api/v1/payments/nmb/callback
# PAYMENT_NMB_ENABLED=false
# NMB_BASE_URL=
# NMB_USERNAME=
# NMB_PASSWORD=
# NMB_MERCHANT_ID=
# NMB_CALLBACK_URL=

# Admin dashboard (optional — defaults to admin@chinaordertz.com)
NEXT_PUBLIC_ADMIN_EMAIL=admin@chinaordertz.com
# Align with API SANCTUM_ADMIN_EXPIRATION_MINUTES (default 480).
ADMIN_TOKEN_MAX_AGE_SECONDS=28800
# ADMIN_API_EMAIL / ADMIN_API_PASSWORD are NOT used for BFF auth (RC1-G4A).

# Admin realtime — Vercel/serverless uses polling by default (no custom WebSocket server).
# NEXT_PUBLIC_ADMIN_REALTIME_MODE=auto | polling | websocket
# NEXT_PUBLIC_WS_BASE_URL=wss://your-domain.com
# NEXT_PUBLIC_ADMIN_WS_URL=wss://your-domain.com/ws/admin/orders
# NEXT_PUBLIC_ORDER_TRACKING_WS_URL=wss://your-domain.com/ws/orders/tracking
# NEXT_PUBLIC_NOTIFICATIONS_WS_URL=wss://your-domain.com/ws/notifications
# Polling interval (ms) for production admin dashboard:
# NEXT_PUBLIC_ADMIN_POLL_INTERVAL_MS=5000
# NEXT_PUBLIC_ADMIN_POLL_INTERVAL_HIDDEN_MS=30000

# Optional persistent order store + Redis pub/sub (Upstash — recommended for Vercel production)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# ADMIN_ORDERS_REDIS_CHANNEL=admin:orders:events
